# Vercel: задайте эти переменные в Project Settings → Environment Variables
# (не загружайте .env в репозиторий)

# Google Gemini — ключ из https://aistudio.google.com/apikey
# Формат AIza... (рекомендуется). Ключи AQ.* работают только для текста и inline-фото.
GEMINI_API_KEY=

# Альтернатива для текста и фото (видео — только Gemini)
OPENAI_API_KEY=

# Модели (опционально)
GEMINI_MODEL=gemini-2.5-flash
OPENAI_MODEL=gpt-4o

# Лимиты
MAX_UPLOAD_MB=50
MAX_TEXT_CHARS=50000
FREE_ANALYSES_PER_MONTH=10
REFERRAL_DISCOUNT_PERCENT=15
PRO_PRICE_USD=9.99
