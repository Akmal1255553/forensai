# Vercel: задайте эти переменные в Project Settings → Environment Variables
# (не загружайте .env в репозиторий)

# --- Supabase (обязательно для продакшена на Vercel) ---
# Создайте проект на https://supabase.com
# Выполните SQL из supabase/migrations/001_profiles.sql
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# JWT Secret: Project Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret

# Google Gemini — ключ из https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Альтернатива для текста и фото (видео — только Gemini)
OPENAI_API_KEY=

# Модели (опционально)
GEMINI_MODEL=gemini-2.5-flash
OPENAI_MODEL=gpt-4o

# Лимиты
MAX_UPLOAD_MB=50
MAX_TEXT_CHARS=50000
FREE_ANALYSES_PER_MONTH=10
REFERRAL_DISCOUNT_PERCENT=15
PRO_PRICE_USD=9.99
